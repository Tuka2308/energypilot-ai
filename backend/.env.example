ENVIRONMENT=development
DATABASE_URL=postgresql://energypilot:energypilot@localhost:5432/energypilot
# AI-чат: с ключом OpenAI чат работает через LLM; без ключа — офлайн-fallback
# (каскад: OpenAI -> Ollama -> детерминированный ответ из контекста).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Локальная модель как офлайн-запасной вариант. Ollama обычно крутится на
# хосте (Mac), не внутри Docker — адрес зависит от того, как запущен backend:
#   backend напрямую (uvicorn, вне Docker):  http://localhost:11434
#   backend в docker-compose:                http://host.docker.internal:11434
# Внутри контейнера "localhost" — это сам контейнер, не хост-машина, поэтому
# при работе через docker-compose localhost здесь не сработает молча (чат
# просто уйдёт в офлайн-fallback без явной ошибки).
OLLAMA_BASE_URL=
OLLAMA_MODEL=llama3.1
# Next.js dev-сервер может занять 3001/3002, если 3000 занят — держим весь
# dev-диапазон (localhost и 127.0.0.1). Не использовать "*".
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:3002"]
